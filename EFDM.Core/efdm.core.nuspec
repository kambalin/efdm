<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata>
		<id>EFDM.Core</id>
		<version>1.8.9</version>
		<authors>Pavel Kambalin</authors>
		<owners>kambalin</owners>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<projectUrl>https://github.com/kambalin/efdm</projectUrl>
		<license type="expression">MIT</license>
		<releaseNotes>
			<![CDATA[
			1.8.9
			- Change namespace to correct in Repository and EFDMDatabaseContext
			- Fixed NullReferenceException in IsCreator: check auditable != null instead of model != null
			- Pass cancellationToken to CountAsync, FetchAsync, FetchIdsAsync in Repository
			- EntityDataQueryBase changed obsolete PredicateBuilder.True<TModel>
				() to
				PredicateBuilder.New<TModel>(true)
			]]>
		</releaseNotes>
		<description>Entity framework data manager</description>
		<tags>entityframeworkcore</tags>
		<dependencies>
			<group targetFramework="net8.0">
				<dependency id="Microsoft.EntityFrameworkCore" version="8.0.26" />
				<dependency id="LinqKit.Microsoft.EntityFrameworkCore" version="8.1.11" />
			</group>
		</dependencies>
	</metadata>
	<files>
		<file src=".\bin\Release\net8.0\EFDM.Core.dll" target="lib\net8.0\EFDM.Core.dll" />
		<file src="..\EFDM.Abstractions\bin\Release\net8.0\EFDM.Abstractions.dll" target="lib\net8.0\EFDM.Abstractions.dll" />
		<file src="..\EFDM.DAL\bin\Release\net8.0\EFDM.DAL.dll" target="lib\net8.0\EFDM.DAL.dll" />
	</files>
</package>